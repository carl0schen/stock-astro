---
// src/layouts/Layout.astro
interface Props {
  title: string;
  date?: string;
  noHeaderMargin?: boolean;
  description?: string;
  image?: string;
}

const { 
  title, 
  date, 
  noHeaderMargin = false,
  description: propDescription,
  image = "/default-og.png"
} = Astro.props;

// 1. 預設的全站描述 (首頁會用到這個)
const defaultDescription = "利用 AI 彙整台股盤後資訊，快速掌握市場動向。";

let finalDescription = propDescription;

// 2. 【核心邏輯修正】
// 條件增加：標題包含「法人買賣超整理」 且 [修改] 標題必須以「數字」開頭 (例如 2026...)
if (!finalDescription && title.includes("法人買賣超整理") && /^\d/.test(title)) {
  
  const datePart = title.split(' ')[0]; 

  if (title.includes("週報")) {
    finalDescription = `本文整理了 ${datePart} 三大法人的交易動向。`;
  } else if (title.includes("月報")) {
    finalDescription = `本文整理了 ${datePart} 三大法人的交易動向。`;
  } else {
    finalDescription = `本文整理了 ${datePart} 台股盤後三大法人的交易動向。`;
  }
}

// 3. 如果經過上面判斷還是空的 (例如首頁)，就用預設值
if (!finalDescription) {
  finalDescription = defaultDescription;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1, maximum-scale=1" name="viewport">
  <meta name="generator" content={Astro.generator} />
  
  <title>{title}</title>
  
  <meta name="description" content={finalDescription} />
  <link rel="canonical" href={canonicalURL} />
  
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={finalDescription} />
  <meta property="og:image" content={socialImageURL} />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={finalDescription} />
  <meta property="twitter:image" content={socialImageURL} />

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css/github-markdown-light.css">
  <link rel="alternate" type="application/rss+xml" title="台股盤後 - 法人買賣超整理" href="/rss.xml">

<style is:global>
  /* ... (維持原本樣式) ... */

<style is:global>
  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    background-color: #fff;
  }

  /* 為了讓 Header 和 文章本體 對齊，我們定義一個共用的寬度變數或類別 */
  .container-width {
    box-sizing: border-box;
    min-width: 200px;
    max-width: 720px; /* 這裡控制全站寬度 */
    margin: 0 auto;
    padding: 0 1rem; /* 左右留一點縫隙 */
  }

  /* --- 頂部導覽列樣式 --- */
  header {
    border-bottom: 1px solid #eaeaea; /* 下方灰線 */
    margin-bottom: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
   
  nav {
    display: flex;
    gap: 1.5rem;
    font-size: 1rem;
    
    /* 強制垂直置中 */
    align-items: center; 
  }

  nav a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
  }
   
  nav a:hover {
    color: #0366d6; /* Github 藍色 */
  }

  /* --- 文章本體樣式 --- */
  body .markdown-body {
    padding-top: 0; /* Header 已經有留白了，這裡歸零 */
    padding-bottom: 2rem;
  }

  /* 表格優化 */
  body .markdown-body table {
    display: block;
    width: 100%;
    overflow-x: auto; 
    margin-bottom: 1.5rem;
  }
  body .markdown-body table { width: 100%; }

  /* --- 底部上一頁/下一頁按鈕樣式 --- */
  .post-nav {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #eaeaea;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .post-nav a {
    text-decoration: none;
    color: #0366d6;
    font-size: 0.95rem;
  }
  .post-nav a:hover {
    text-decoration: underline;
  }
</style>
</head>
<body>
    <header>
        <div class="container-width">
            <nav>
                <a href="/">首頁</a>
                <a href="/search/">搜尋</a>
                <a href="/news/">盤後新聞</a>
                <a href="/rss.xml">RSS</a>
                <a href="/contact/">聯絡我們</a>
            </nav>
        </div>
    </header>

    <main class="container-width markdown-body">
        <slot />
    </main>
</body>
</html>