---
// src/layouts/Layout.astro
interface Props {
  title: string;
  date?: string;
  noHeaderMargin?: boolean; // 新增這個選用參數，預設是 undefined
  description?: string;     // [新增] SEO 描述
  image?: string;           // [新增] 社群預覽圖片
}

// 接收參數，設定預設值
const { 
  title, 
  date, 
  noHeaderMargin = false,
  description = "利用 AI 彙整台股盤後資訊，快速掌握市場動向。", // [預設描述]
  image = "/default-og.png" // [預設圖片] 請確保 public 資料夾有這張圖
} = Astro.props;

// 產生標準網址 (Canonical URL)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

// [新增] 產生圖片的絕對路徑 (OG 標籤強制要求絕對路徑 https://...)
const socialImageURL = new URL(image, Astro.site);
---

<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta content="width=device-width, initial-scale=1, maximum-scale=1" name="viewport">
  <meta name="generator" content={Astro.generator} />
  
  <title>{title}</title>
  
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={socialImageURL} />

  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:url" content={canonicalURL} />
  <meta property="twitter:title" content={title} />
  <meta property="twitter:description" content={description} />
  <meta property="twitter:image" content={socialImageURL} />

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/github-markdown-css/github-markdown-light.css">
  <link rel="alternate" type="application/rss+xml" title="台股盤後 - 法人買賣超整理" href="/rss.xml">

<style is:global>
  html {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    background-color: #fff;
  }

  /* 為了讓 Header 和 文章本體 對齊，我們定義一個共用的寬度變數或類別 */
  .container-width {
    box-sizing: border-box;
    min-width: 200px;
    max-width: 720px; /* 這裡控制全站寬度 */
    margin: 0 auto;
    padding: 0 1rem; /* 左右留一點縫隙 */
  }

  /* --- 頂部導覽列樣式 --- */
  header {
    border-bottom: 1px solid #eaeaea; /* 下方灰線 */
    margin-bottom: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
   
  nav {
    display: flex;
    gap: 1.5rem;
    font-size: 1rem;
    
    /* 強制垂直置中 */
    align-items: center; 
  }

  nav a {
    text-decoration: none;
    color: #555;
    font-weight: 500;
  }
   
  nav a:hover {
    color: #0366d6; /* Github 藍色 */
  }

  /* --- 文章本體樣式 --- */
  body .markdown-body {
    padding-top: 0; /* Header 已經有留白了，這裡歸零 */
    padding-bottom: 2rem;
  }

  /* 表格優化 */
  body .markdown-body table {
    display: block;
    width: 100%;
    overflow-x: auto; 
    margin-bottom: 1.5rem;
  }
  body .markdown-body table { width: 100%; }

  /* --- 底部上一頁/下一頁按鈕樣式 --- */
  .post-nav {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #eaeaea;
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }
  .post-nav a {
    text-decoration: none;
    color: #0366d6;
    font-size: 0.95rem;
  }
  .post-nav a:hover {
    text-decoration: underline;
  }
</style>
</head>
<body>
    <header>
        <div class="container-width">
            <nav>
                <a href="/">首頁</a>
                <a href="/search/">搜尋</a>
                <a href="/news/">盤後新聞</a>
                <a href="/rss.xml">RSS</a>
                <a href="/contact/">聯絡我們</a>
            </nav>
        </div>
    </header>

    <main class="container-width markdown-body">
        <slot />
    </main>
</body>
</html>