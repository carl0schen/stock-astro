---
// src/pages/[year]/weekly/[week]/index.astro
import { getCollection } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('weekly');
  
  // 1. 排序
  const sortedPosts = allPosts.sort((a, b) => a.slug.localeCompare(b.slug));

  return sortedPosts.map((post, index) => {
    // 2. 解析 Slug (例如: 2026/W01)
    const parts = post.slug.split('/');
    const year = parts[0];
    const rawWeek = parts[1]; // 這裡是 W01

    // 3. 【重要】把 W 拿掉，變成 01
    const week = rawWeek.replace(/[wW]/, '');

    // 4. 找出鄰居
    const prevPost = index > 0 ? sortedPosts[index - 1] : null;
    const nextPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;

    return {
      // 5. 【重要】這裡的 key 必須跟檔名 [year], [week] 一模一樣
      params: { year, week }, 
      props: { 
        post, 
        prevPost, 
        nextPost 
      },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();

// 輔助函式：產生連結
function getUrl(slug) {
   const [y, w] = slug.split('/');
   return `/${y}/weekly/${w.replace(/[wW]/, '')}/`;
}
---

<Layout title={post.data.title} date={post.data.date}>
  <Content />

  <div class="post-nav">
    <div>
      {prevPost && (
        <a href={getUrl(prevPost.slug)}>
           ← {prevPost.data.title}
        </a>
      )}
    </div>
    <div>
      {nextPost && (
        <a href={getUrl(nextPost.slug)}>
          {nextPost.data.title} →
        </a>
      )}
    </div>
  </div>
</Layout>