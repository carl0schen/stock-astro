---
// src/pages/[year]/weekly/[week]/index.astro
import { getCollection, render } from 'astro:content';
import Layout from '../../../../layouts/Layout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('weekly');
  
  // 改用 id 排序
  const sortedPosts = allPosts.sort((a, b) => a.id.localeCompare(b.id));

  return sortedPosts.map((post, index) => {
    // 清除 .md 後再解析
    const cleanId = post.id.replace(/\.md$/, '');
    const parts = cleanId.split('/');
    const year = parts[0];
    const rawWeek = parts[1]; 

    const week = rawWeek.replace(/[wW]/, '');

    const prevPost = index > 0 ? sortedPosts[index - 1] : null;
    const nextPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;

    return {
      params: { year, week }, 
      props: { post, prevPost, nextPost },
    };
  });
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);

function getUrl(id: string) {
   const cleanId = id.replace(/\.md$/, '');
   const [y, w] = cleanId.split('/');
   return `/${y}/weekly/${w.replace(/[wW]/, '')}/`;
}
---

<Layout title={post.data.title} date={post.data.date}>
  <Content />

  <div class="post-nav">
    <div>
      {prevPost && (
        <a href={getUrl(prevPost.id)}>
           ← {prevPost.data.title}
        </a>
      )}
    </div>
    <div>
      {nextPost && (
        <a href={getUrl(nextPost.id)}>
          {nextPost.data.title} →
        </a>
      )}
    </div>
  </div>
</Layout>